<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Post – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-sm">

    <div class="page-header" style="display:flex;align-items:center;gap:14px;">
      <a href="/noticeboard" class="btn btn-ghost btn-sm">← Back</a>
      <h1 class="page-title">Edit Post</h1>
    </div>

    <% const msgArr = Array.isArray(msg) ? msg : (msg ? [msg] : []); %>
    <% if (msgArr.includes('edit successful')) { %>
      <div class="alert alert-success">Post updated successfully.</div>
    <% } else if (msgArr.length > 0) { %>
      <div class="alert alert-error"><%= msgArr.join(' · ') %></div>
    <% } %>

    <% if (result) { %>
      <div class="form-card">
        <form action="/noticeboard/update/<%= result._id %>" method="POST">
          <div class="form-group">
            <label class="form-label">Your Post</label>
            <textarea class="form-textarea" name="message" required rows="4"><%= result.message %></textarea>
          </div>
          <input type="hidden" name="userID" value="<%= result.userID %>">
          <div class="form-actions">
            <a href="/noticeboard" class="btn btn-ghost">Cancel</a>
            <button class="btn btn-primary" type="submit">Save Changes</button>
          </div>
        </form>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>Post not found.</p>
        <a href="/noticeboard" class="btn btn-ghost" style="margin-top:16px;display:inline-flex;">Back to Noticeboard</a>
      </div>
    <% } %>

  </div>
</body>
</html>
