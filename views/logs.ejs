<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Activity Logs – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container">

    <div class="page-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <h1 class="page-title">Activity Logs</h1>
        <p class="page-subtitle">
          Viewing logs for <strong><%= user.name %></strong>
          <% if (user.superAdmin) { %>
            &nbsp;<span class="superadmin-badge">Super Admin</span>
          <% } else if (user.admin) { %>
            &nbsp;<span class="admin-badge">Admin</span>
          <% } else { %>
            &nbsp;<span class="user-badge">User</span>
          <% } %>
        </p>
      </div>
      <a href="/admin" class="btn btn-ghost btn-sm">← Back to Admin</a>
    </div>

    <% if (userLogs.length === 0) { %>
      <div class="empty-state">
        <p>No activity recorded for this user yet.</p>
      </div>
    <% } else { %>

      <div class="logs-summary">
        <span class="logs-count"><%= userLogs.length %> log<%= userLogs.length === 1 ? '' : 's' %> total</span>
      </div>

      <div class="logs-table-wrap">
        <table class="admin-table logs-table">
          <thead>
            <tr>
              <th>Action</th>
              <th>Category</th>
              <th>Date &amp; Time</th>
              <th>Link</th>
            </tr>
          </thead>
          <tbody>
            <% userLogs.forEach(log => { %>
              <tr>
                <td>
                  <span class="log-action-text"><%= log.action %></span>
                </td>
                <td>
                  <span class="log-category-badge log-category-<%= log.category ? log.category.toLowerCase().replace(/\s+/g,'-') : 'other' %>">
                    <%= log.category %>
                  </span>
                </td>
                <td class="log-date">
                  <%= log.createdAt.toLocaleDateString('en-GB', {
                    weekday: 'short', year: 'numeric', month: 'short',
                    day: '2-digit', hour: '2-digit', minute: '2-digit'
                  }) %>
                </td>
                <td>
                  <% if (log.targetId && log.category === 'movie') { %>
                    <% if (log.isDeleted) {%>
                      <p style="color:var(--text-3);font-size:13px;">Movie was deleted</p>
                    <% } else { %>
                      <a class="btn btn-sm btn-secondary" href="/movie/<%= log.targetId %>">View Movie</a>
                    <% } %>
                  <% } else if (log.targetId && log.category === 'review') { %>
                    <% if (log.isDeleted) {%>
                      <p style="color:var(--text-3);font-size:13px;">Review was deleted</p>
                    <% } else { %>
                      <a class="btn btn-sm btn-secondary" href="/movie/<%= log.targetId %>#reviews">View Review</a>
                    <% } %>
                  <% } else if (log.targetId && log.category === 'post') { %>
                    <% if (log.isDeleted) {%>
                      <p style="color:var(--text-3);font-size:13px;">Post was deleted</p>
                    <% } else { %>
                      <a class="btn btn-sm btn-secondary" href="/discussionboard">View Post</a>
                    <% } %>
                  <% } else if (log.targetId && log.category === 'reply') { %>
                    <a class="btn btn-sm btn-secondary" href="/discussionboard/<%= log.targetId %>/replies">View Reply Thread</a>
                  <% } else { %>
                    <span style="color:var(--text-3);font-size:13px;">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

    <% } %>
  </div>
</body>
</html>
