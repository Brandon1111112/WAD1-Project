<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logs</title>
</head>
<body>
    <h2>Activity log for <%= user.name %></h2>

    <% if (userLogs.length === 0) { %>
    <p>No activity recorded for this user.</p>
    <% } else { %>
        <table border="1">
            <thead>
            <tr>
                <th>Action</th>
                <th>Category</th>
                <th>Date</th>
                <th>Link</th>
            </tr>
            </thead>
            <tbody>
            <% userLogs.forEach(log => { %>
                <tr>
                <td><%= log.action %></td>
                <td><%= log.category %></td>
                <td><%= log.createdAt.toLocaleDateString("en-GB", { weekday: "short", year: "numeric", month: "short", day: "2-digit", hour: "2-digit", minute: "2-digit"}) %>
                </td>
                <td>
                    <% if (log.targetId && log.targetModel === 'Movie') { %>
                        <a href="/movie/<%= log.targetId %>">View Movie</a>
                    <% } else if ((log.targetId && log.targetModel === 'Review')){ %>
                        <a href="/movie/<%= log.targetId %>#reviews">View Review</a>
                    <% } else { %>
                        -
                    <% } %>
                </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    <% } %>

    <a href="/admin">Back to Admin</a>
</body>
</html>