<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Confirm Deletion – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-xs" style="padding-top:48px; text-align:center;">
    <div class="confirm-card" style="max-width:420px; margin:0 auto;">
      <h2 style="margin-bottom:12px;">Confirm Account Deletion</h2>
      <p style="margin-bottom:20px;">Are you sure you want to delete your account?</p>
      <div style="display:flex; justify-content:center; gap:10px;">
        <form action="/profile/delete" method="POST" style="margin:0;">
          <button class="btn btn-danger" type="submit">Yes, delete</button>
        </form>
        <a href="/profile" class="btn btn-secondary">No, go back</a>
      </div>
    </div>
  </div>
</body>
</html>
