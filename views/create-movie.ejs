<h1>Create movie page</h1>
<form action="/movie/create" method="POST">
  <label for="movieTitle">Movie Title</label>
  <input type="text" name="movieTitle" /><br /><br />
  <label for="movieDescription">Movie description</label>
  <input type="text" name="movieDescription" /><br /><br />
  <label for="movieRating">Movie Rating</label>
  <input type="number" name="movieRating" /><br><br>
  <label for="releaseDate"></label>
  <input type="date" name="releaseDate" /><br><br>
  <button type="submit">Create Movie</button>
</form>
