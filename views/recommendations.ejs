<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Discover – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container">
    <div class="page-header">
      <h1 class="page-title">Recommended for You</h1>
    </div>

    
    <% if (favoriteRecommendations.length > 0) { %>
      <% if (userFavouriteGenres.length > 0) { %>
      <p style="font-size:13px;color:var(--text-2);margin-bottom:10px;">Based on your favourite genre<%= userFavouriteGenres.length === 1 ? '' : 's'%> you seem to enjoy:</p>
      <div class="genre-chips">
        <% userFavouriteGenres.forEach(genre => { %><span class="genre-chip"><%= genre %></span><% }) %>
      </div>
      <% } %>
      <div class="movie-grid">
        <% favoriteRecommendations.forEach(movie => { %>
          <div class="movie-card">
            <a href="/movie/<%= movie._id %>">
              <% if (movie.moviePoster) { %>
                <img class="movie-poster" src="<%= movie.moviePoster %>" alt="<%= movie.movieTitle %>" />
              <% } else { %>
                <div class="movie-poster-placeholder">🎬</div>
              <% } %>
            </a>
            <div class="movie-card-body">
              <div class="movie-title"><a href="/movie/<%= movie._id %>"><%= movie.movieTitle %></a></div>
              <% if (movie.genre) { %><span class="genre-tag"><%= movie.genre %></span><% } %>
              <div class="movie-rating">
                  <% const rating = ratingSummaries.find(r =>
                    r._id.toString() === movie._id.toString()
                    ); %>

                  <% if (rating) { %>
                    ★ <%= rating.avgRating.toFixed(1) %>
                      <span style="color:var(--text-3);font-weight:400;">/ 5</span>
                      <span style="color:var(--text-3);font-weight:400;">(<%= rating.totalReviews %>)</span>
                  <% } else { %>
                        <span style="color:var(--text-3);font-weight:400;">No ratings yet</span>
                  <% } %>
                </div>
              <div class="actions">
                <form action="/watchlist/add" method="POST">
                  <input type="hidden" name="movieId" value="<%= movie._id %>">
                  <button class="btn btn-sm btn-secondary" type="submit">+ Watchlist</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    
    <% if (recommendations.length > 0) { %>
      <% if (topGenres.length > 0) { %>
      <p style="font-size:13px;color:var(--text-2);margin-bottom:10px;">Based on what you have watched you seem to enjoy:</p>
      <div class="genre-chips">
        <% topGenres.forEach(genre => { %><span class="genre-chip"><%= genre %></span><% }) %>
      </div>
      <% } %>
      <div class="movie-grid">
        <% recommendations.forEach(movie => { %>
          <div class="movie-card">
            <a href="/movie/<%= movie._id %>">
              <% if (movie.moviePoster) { %>
                <img class="movie-poster" src="<%= movie.moviePoster %>" alt="<%= movie.movieTitle %>" />
              <% } else { %>
                <div class="movie-poster-placeholder">🎬</div>
              <% } %>
            </a>
            <div class="movie-card-body">
              <div class="movie-title"><a href="/movie/<%= movie._id %>"><%= movie.movieTitle %></a></div>
              <% if (movie.genre) { %><span class="genre-tag"><%= movie.genre %></span><% } %>
              <div class="movie-rating">
                  <% const rating = ratingSummaries.find(r =>
                    r._id.toString() === movie._id.toString()
                    ); %>

                  <% if (rating) { %>
                    ★ <%= rating.avgRating.toFixed(1) %>
                      <span style="color:var(--text-3);font-weight:400;">/ 5</span>
                      <span style="color:var(--text-3);font-weight:400;">(<%= rating.totalReviews %>)</span>
                  <% } else { %>
                        <span style="color:var(--text-3);font-weight:400;">No ratings yet</span>
                  <% } %>
                </div>
              <div class="actions">
                <form action="/watchlist/add" method="POST">
                  <input type="hidden" name="movieId" value="<%= movie._id %>">
                  <button class="btn btn-sm btn-secondary" type="submit">+ Watchlist</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (favoriteRecommendations.length === 0 && recommendations.length === 0){%>
      <div class="empty-state">
        <p>No recommendations yet. <a href="/movie">Watch more movies</a> or <a href="/profile/edit">select your favourite genres</a> to get personalised picks!</p>
      </div>
    <% } %>
    <div style="margin-top:16px;display:flex;gap:12px;">
      <a href="/watchlist" class="btn btn-ghost btn-sm">← Watchlist</a>
      <a href="/home" class="btn btn-ghost btn-sm">Home</a>
    </div>
  </div>
</body>
</html>
