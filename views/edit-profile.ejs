<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Profile – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-sm">
    <div class="page-header">
      <h1 class="page-title">Edit Profile</h1>
      <p class="page-subtitle">Update your personal information</p>
    </div>

    <div class="form-card">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/profile/edit" method="POST">
        <div class="form-section">
          <h3 class="form-section-title">Account Details</h3>
          <div class="form-group">
            <label class="form-label">Full Name</label>
            <input class="form-input" type="text" name="name" value="<%= user.name %>" required />
          </div>
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <input class="form-input" type="email" name="email" value="<%= user.email %>" required />
          </div>
          <div class="form-group">
            <label class="form-label">New Password</label>
            <input class="form-input" type="password" name="password" placeholder="Leave blank to keep current password" />
            <small style="color: var(--text-3); font-size: 12px; margin-top: 4px; display: block;">
              Only enter if you want to change your password
            </small>
          </div>
        </div>

        <div class="form-divider"></div>

        <div class="form-section">
          <h3 class="form-section-title">Favorite Genres</h3>
          <p style="color: var(--text-2); font-size: 13px; margin-bottom: 16px;">
            Select the genres you enjoy most to get better recommendations
          </p>
          <div class="genre-checkboxes">
            <% genreOptions.forEach(function(genre) { %>
              <label class="genre-checkbox">
                <input
                  type="checkbox"
                  name="genres"
                  value="<%= genre %>"
                  <%= (user.favoriteGenres || []).includes(genre) ? 'checked' : '' %> /> <!-- Loop through genre options, check if each genre is in user's favorite genres -->
                <span class="checkbox-label"><%= genre %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <div class="form-actions" style="margin-top: 32px;">
          <a href="/profile" class="btn btn-ghost btn-lg">Cancel</a>
          <button class="btn btn-primary btn-lg" type="submit">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
