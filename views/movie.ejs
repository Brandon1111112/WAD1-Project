<!DOCTYPE html>
<html>

<head>
    <title>
        <%= movie.title %>
        <%= movie.movieTitle %>
    </title>

</head>

<body>
    <%- include('partials/navbar') %>
        <h1>
            <%= movie.title %>
                <%= movie.movieTitle %>
        </h1>

        <p>
            <%= movie.description %>
            <%= movie.movieDescription %>
        </p>

        <a href="/movie/edit/<%= movie._id %>">Edit</a>
        <a href="/movie/delete/<%= movie._id %>">Delete</a>

        <h2>Reviews</h2>

        <% if (error) { %>
            <p style="color: red;">
                <%= error %>
            </p>
            <% } %>

                <form action="/movie/<%= movie._id %>/review" method="POST">
                    <label for="rating">Rating (1–5):</label><br>
                    <select id="rating" name="rating" required>
                        <option value="">Select rating</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                    <br><br>

                    <label for="review">Your review:</label><br>
                    <textarea id="review" name="review" rows="5" cols="40" placeholder="Write your review here..."
                        required></textarea>
                    <br><br>

                    <button type="submit">Submit Review</button>
                </form>

                <% if (reviews && reviews.length> 0) { %>
                    <% reviews.forEach(function(r) { %>
                        <hr>
                        <p><strong>
                                <%= r.userId ? r.userId.name : "Unknown User" %>
                            </strong></p>
                        <p><strong>Rating:</strong>
                            <%= r.rating %> / 5
                        </p>
                        <p><strong>Review:</strong></p>
                        <p>
                            <%= r.review %>
                        </p>
                        <% if (currentUser && r.userId && r.userId._id.toString()===currentUser.userId) { %>
                            <a href="/movie/review/edit/<%= r._id %>">Edit</a>

                            <form action="/movie/review/delete/<%= r._id %>" method="POST" style="display:inline;">
                                <button type="submit">Delete</button>
                            </form>
                            <% } %>
                            <% }) %>
                        <% } else { %>
                            <p>No reviews yet.</p>
                        <% } %>

</body>

</html>