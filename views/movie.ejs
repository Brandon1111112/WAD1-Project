<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= movie.movieTitle %> – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <main>
    <div class="detail-hero">
      <% if (movie.moviePoster) { %>
        <div class="detail-poster-wrap">
          <img src="<%= movie.moviePoster %>" alt="<%= movie.movieTitle %> poster" />
        </div>
      <% } else { %>
        <div class="detail-poster-placeholder">🎬</div>
      <% } %>

      <div class="detail-info">
        <div class="detail-breadcrumb">
          <a href="/movie">Movies</a> › <span><%= movie.movieTitle %></span>
        </div>
        <h1 class="detail-title"><%= movie.movieTitle %></h1>
        <div class="detail-meta-row">
          <span><%= new Date(movie.releaseDate).getFullYear() %></span>
          <span class="meta-sep">·</span>
          <span>Rating: <%= movie.movieRating %>/5</span>
        </div>
        <% if (movie.movieRating) { %>
          <div class="detail-rating-badge">
            <span class="rating-star">★</span>
            <span class="rating-val"><%= movie.movieRating %></span>
            <span class="rating-cap">/ 5</span>
          </div>
        <% } %>
        <p class="detail-description"><%= movie.movieDescription %></p>

        <div class="detail-actions">
          <% if (watchlist.includes(movie._id.toString())) { %>
            <form action="/watched/remove" method="POST">
              <input type="hidden" name="movieId" value="<%= movie._id %>">
              <button class="btn btn-ghost" type="submit">− Remove from Watchlist</button>
            </form>
          <% } else { %>
            <form action="/watched/add" method="POST">
              <input type="hidden" name="movieId" value="<%= movie._id %>">
              <button class="btn btn-secondary" type="submit">+ Add to Watchlist</button>
            </form>
          <% } %>
          <% if (alreadyWatched.includes(movie._id.toString())) { %>
            <form action="/watched/unwatch" method="POST">
              <input type="hidden" name="movieId" value="<%= movie._id %>">
              <button class="btn btn-ghost" type="submit">Unmark as Watched</button>
            </form>
          <% } else { %>
            <form action="/watched/watch" method="POST">
              <input type="hidden" name="movieId" value="<%= movie._id %>">
              <button class="btn btn-primary" type="submit">✓ Mark as Watched</button>
            </form>
          <% } %>
          <a class="btn" href="/movie/edit/<%= movie._id %>">Edit</a>
          <a class="btn btn-danger" href="/movie/delete/<%= movie._id %>">Delete</a>
        </div>
      </div>
    </div>

    <div class="detail-body">
      <div>
        <!-- Reviews -->
        <div class="detail-section" id="reviews">
          <h2 class="detail-section-title">Reviews</h2>
          <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
          <% } %>
          <div class="review-form">
            <form action="/movie/<%= movie._id %>/review" method="POST">
              <div class="form-group">
                <label class="form-label">Your Rating</label>
                <select class="form-select" name="rating" required style="max-width:160px;">
                  <option value="">Select…</option>
                  <option value="1">1 – Poor</option>
                  <option value="2">2 – Fair</option>
                  <option value="3">3 – Good</option>
                  <option value="4">4 – Great</option>
                  <option value="5">5 – Excellent</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Your Review</label>
                <textarea class="form-textarea" name="review" placeholder="Share your thoughts…" required></textarea>
              </div>
              <button class="btn btn-primary" type="submit">Submit Review</button>
            </form>
          </div>

          <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(function(r) { %>
              <div class="review-card">
                <div class="review-card-header">
                  <span class="reviewer-name"><%= r.userId ? r.userId.name : 'Anonymous' %></span>
                  <span class="review-rating">★ <%= r.rating %>/5</span>
                </div>
                <div class="review-text"><%= r.review %></div>
                <% if (currentUser && r.userId && r.userId._id.toString() === currentUser.userId) { %>
                  <div class="review-actions">
                    <a class="btn btn-sm btn-secondary" href="/movie/review/edit/<%= r._id %>">Edit</a>
                    <form action="/movie/review/delete/<%= r._id %>" method="POST" style="display:inline;">
                      <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% }) %>
          <% } else { %>
            <p class="no-reviews">No reviews yet. Be the first to share your thoughts!</p>
          <% } %>
        </div>
      </div>

      <div>
        <div class="sidebar-card">
          <div class="sidebar-card-title">Details</div>
          <div class="sidebar-fact">
            <span class="fact-label">Release</span>
            <span class="fact-value"><%= new Date(movie.releaseDate).toLocaleDateString('en-GB',{year:'numeric',month:'long',day:'numeric'}) %></span>
          </div>
          <div class="sidebar-fact">
            <span class="fact-label">Rating</span>
            <span class="fact-value"><%= movie.movieRating %> / 5</span>
          </div>
          <div class="sidebar-fact">
            <span class="fact-label">Reviews</span>
            <span class="fact-value"><%= reviews ? reviews.length : 0 %></span>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
