<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
    <style>
        body {
            background-image: url('/img/auth_background.png');
            background-size: cover; 
            height: 85.2vh;
            width: 99%;
        }

        .container{
            font-family: Arial, Helvetica, sans-serif;
            text-align:center;
            padding:40px 35px;
            margin:100px auto;

            background:white;     
            width:100%;
            max-width:400px;      
            border-radius:12px;   
            box-shadow:0 10px 30px rgba(0,0,0,0.2); /* soft shadow */
        }

        form{
            width:100%;
            max-width:320px;
            margin:0 auto;
            text-align:left;
        }

        label{
            display:block;
            margin-bottom:6px;
        }

        input{
            width:100%;
            padding:8px 0;
            border:none;
            border-bottom:2px solid #ccc;
            margin-bottom:18px;
            font-size:16px;
            background:transparent;
        }

        input:focus{
            outline:none;
            border-bottom:2px solid black;
        }

        input::placeholder{
            font-size:12px;
            color:#999;
        }

        button{
            width:100%;
            padding:10px;
            background-color:#4CAF50;
            border-radius:30px;
            color:white;
            border:none;
            cursor:pointer;
            font-weight:bold;
        }

        button:hover{
            background-color:#45a049;
        }

        .error{
            color:red;
            font-size:14px;
            margin-bottom:12px;
            text-align:center;
        }

        .link{
            text-align:center;
            margin-top:15px;
        }

</style>
</head>
<body>
    <div class="container">
        <h2>Login Page</h2>
        <form method="post" action="/login">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Enter your email..." required><br><br>

            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="Enter your password..." required><br><br>

            <p class="error"><%= error %></p>

            <button type="submit">Login</button>

            <p class = "link">Don't have an account? Sign up <a href="/register">here</a></p>
        </form>
    </div>
</body>
</html>