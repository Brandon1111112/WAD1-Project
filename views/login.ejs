<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-logo">IAM<span>db</span></div>
      <div class="auth-sub">Sign in to your account</div>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label class="form-label">Email</label>
          <input class="form-input" type="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input class="form-input" type="password" name="password" placeholder="••••••••" required />
        </div>
        <button class="btn btn-primary btn-block btn-lg" type="submit" style="margin-top:8px;">Sign In</button>
      </form>
      <div class="auth-switch">Don't have an account? <a href="/register">Create one →</a></div>
    </div>
  </div>
</body>
</html>
