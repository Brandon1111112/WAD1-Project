<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IAMdb – Your Movie Companion</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <main>
    <section class="hero">
      <div class="hero-eyebrow">Your cinematic companion</div>
      <h1 class="hero-title">Discover films<br>worth <em>watching</em></h1>
      <p class="hero-tagline">Track, rate, and review your favourite movies. Find your next obsession.</p>
      <a href="/movie" class="cta-btn">Browse all movies</a>
    </section>
    <section class="features">
      <div class="feature">
        <div class="feature-icon">🎬</div>
        <div class="feature-title">Track Watched Movies</div>
        <div class="feature-desc">Keep a personal log of every movie you've seen.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">📝</div>
        <div class="feature-title">Write Reviews</div>
        <div class="feature-desc">Share your thoughts and read what others think.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">⭐</div>
        <div class="feature-title">Rate Movies</div>
        <div class="feature-desc">Give ratings and see what's trending in the community.</div>
      </div>
      <div class="feature">
        <div class="feature-icon">📋</div>
        <div class="feature-title">Manage Watchlist</div>
        <div class="feature-desc">Save movies you want to watch and never miss out.</div>
      </div>
    </section>
  </main>
</body>
</html>
