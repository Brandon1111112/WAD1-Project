<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Movie – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-sm">
    <div class="page-header">
      <h1 class="page-title">Edit Movie</h1>
      <p class="page-subtitle"><%= movie.movieTitle %></p>
    </div>
    <div class="form-card">
      <form action="/movie/edit/<%= movie._id %>" method="POST">
        <div class="form-group">
          <label class="form-label">Movie Title</label>
          <input class="form-input" type="text" name="movieTitle" value="<%= movie.movieTitle %>" required />
        </div>
        <div class="form-group">
            <label class="form-label">Genre</label>
            <select
              class="form-select"
              name="genre"
              required
              style="max-width: 160px"
            >
              <option value="">Select…</option>
              <option value="Comedy" <%= movie.genre === 'Comedy' ? 'selected' : '' %>>Comedy</option>
              <option value="Sci-Fi" <%= movie.genre === 'Sci-Fi' ? 'selected' : '' %>>Sci-Fi</option>
              <option value="Drama" <%= movie.genre === 'Drama' ? 'selected' : '' %>>Drama</option>
              <option value="Action" <%= movie.genre === 'Action' ? 'selected' : '' %>>Action</option>
              <option value="Horror" <%= movie.genre === 'Horror' ? 'selected' : '' %>>Horror</option>
              <option value="Anime" <%= movie.genre === 'Anime' ? 'selected' : '' %>>Anime</option>
              <option value="Fantasy" <%= movie.genre === 'Fantasy' ? 'selected' : '' %>>Fantasy</option>
            </select>
          </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea class="form-textarea" name="movieDescription" required><%= movie.movieDescription %></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Release Date</label>
          <input class="form-input" type="date" name="releaseDate" value="<%= movie.releaseDate.toISOString().split('T')[0] %>" required />
        </div>
        <div class="form-actions">
          <a href="/movie/<%= movie._id %>" class="btn btn-ghost">Cancel</a>
          <button class="btn btn-primary" type="submit">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
