<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container">
    <div class="admin-header">
      <div class="page-header" style="border:none;margin-bottom:0;padding-bottom:0;">
        <h1 class="page-title">Admin Panel</h1>
        <p class="page-subtitle">Manage users and permissions</p>
      </div>
      <a href="/admin/create-user" class="btn btn-primary">+ Create User</a>
    </div>

    <!-- Action forms rendered outside deleteForm, as it kept causing nesting issues
         I then linked to their buttons below via the form="make/demote-admin-i being the user position in the table" attribute using the loop index. -->
    <% Users.forEach((user, i) => { %>
      <% if (!user.admin) { %>
        <form id="make-admin-<%= i %>" action="/admin/make-admin" method="POST">
          <input type="hidden" name="email" value="<%= user.email %>">
        </form>
      <% } else if (user.admin && !user.superAdmin) { %>
        <form id="demote-admin-<%= i %>" action="/admin/demote-admin" method="POST">
          <input type="hidden" name="email" value="<%= user.email %>">
        </form>
      <% } %>
    <% }) %>

    <form id="deleteForm" action="/admin/confirm-delete" method="POST">
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width:40px;">Select</th>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
        <% let loggedUser = user; %> <!-- The currently logged-in user session-->
        <!--Loop below for the users display in checkboxes-->
          <!-- index i to forEach to match action form IDs above -->
          <% Users.forEach((user, i) => { %>
            <tr>
              <td><input type="checkbox" name="emails" value="<%= user.email %>"></td>
              <td><%= user.name %></td>
              <td style="color:var(--text-2);"><%= user.email %></td>
              <td>
                <!--Check if the user is an admin for the badge -->
                <% if (user.superAdmin) { %>
                  <span class="superadmin-badge">Super Admin</span>
                <% } else if (user.admin) { %>
                  <span class="admin-badge">Admin</span>
                <% } else { %>
                  <span class = "user-badge">User</span>
                <% } %>
              </td>
              <td>
                <% if (loggedUser.superAdmin) { %> 
                    <!-- Show make admin/demote admin options if current user is a superadmin -->
                    <% if (!user.admin) { %>
                    <!-- If user not an admin: Show make Admin option -->
                    <button class="btn btn-sm btn-secondary" type="submit" form="make-admin-<%= i %>">Make Admin</button>
                    <% } else if (user.admin && !user.superAdmin) { %>
                    <!-- If user is an admin but not a superadmin: Show demote admin option -->
                    <button class="btn btn-sm btn-danger" type="submit" form="demote-admin-<%= i %>">Remove Admin</button>
                    <% } %>
                <% } else if (loggedUser.admin) { %> <!-- If user is an admin: Show make Admin option but not demote admin option -->
                    <% if (!user.admin && !user.superAdmin) { %>
                    <!-- If user is an admin: Show make Admin option but not demote admin option -->
                    <button class="btn btn-sm btn-secondary" type="submit" form="make-admin-<%= i %>">Make Admin</button>
                    <% } %>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <div style="margin-top:16px;display:flex;justify-content:flex-end;">
        <button class="btn btn-danger" type="submit">Delete Selected Users</button>
      </div>
    </form>
  </div>
</body>
</html>