<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Delete Movie – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-xs" style="padding-top:48px;">
    <div class="confirm-card">
      <div class="confirm-title">Delete Movie</div>
      <h3 style="font-family:var(--serif);font-size:20px;margin:8px 0 4px;"><%= movie.movieTitle %></h3>
      <p style="font-size:13px;color:var(--text-2);margin-bottom:0;"><%= movie.movieDescription %></p>
      <div class="confirm-warning">
        This action is permanent and cannot be undone. All reviews for this movie will also be deleted.
      </div>
      <form action="/movie/delete/<%= movie._id %>" method="POST">
        <div class="confirm-actions">
          <a href="/movie/<%= movie._id %>" class="btn btn-ghost">Cancel</a>
          <button class="btn btn-danger" type="submit">Delete Movie</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
