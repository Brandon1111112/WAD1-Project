<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Delete Movie</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>
    <main>
      <div
        class="movie-card"
        style="
          max-width: 420px;
          margin: 48px auto 0 auto;
          padding: 32px 28px 28px 28px;
          box-shadow: 0 2px 12px rgba(200, 0, 0, 0.08);
        "
      >
        <h2
          style="
            color: #c00;
            text-align: center;
            margin-bottom: 10px;
            font-weight: 700;
          "
        >
          Delete Movie
        </h2>
        <h3 class="movie-title" style="text-align: center; margin-bottom: 8px">
          <%= movie.movieTitle %>
        </h3>
        <p class="movie-meta" style="text-align: center">
          <%= movie.movieDescription %>
        </p>
        <p class="movie-meta" style="text-align: center">
          Rating: <%= movie.movieRating %> / 5
        </p>
        <div
          style="
            background: #ffeaea;
            color: #c00;
            padding: 10px 14px;
            border-radius: 8px;
            margin: 18px 0 10px 0;
            text-align: center;
            font-size: 1rem;
          "
        >
          Are you sure you want to delete this movie? This action cannot be
          undone.
        </div>
        <form
          action="/movie/delete/<%= movie._id %>"
          method="post"
          style="
            margin-top: 18px;
            display: flex;
            gap: 10px;
            justify-content: center;
          "
        >
          <button
            class="btn"
            style="background: #c00; color: #fff; min-width: 120px"
            type="submit"
          >
            Delete
          </button>
          <a
            class="btn"
            href="/movie/<%= movie._id %>"
            style="background: #eee; color: #222"
            >Cancel</a
          >
        </form>
      </div>
    </main>
  </body>
</html>
