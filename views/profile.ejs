<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile – IAMdb</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>
    <div class="profile-page">
      <div class="profile-card">
        <img
          src="/img/default-profile.jpg"
          class="profile-img"
          alt="Profile picture"
        />
        <div class="profile-name"><%= user.name %></div>
        <div class="profile-email"><%= user.email %></div>
        <div class="profile-stats">
          <div class="stat">
            <span class="stat-val"><%=watchedCount%></span>
            <span class="stat-label">Watched</span>
          </div>
          <div class="stat">
            <span class="stat-val"><%=reviewCount%></span>
            <span class="stat-label">Reviews</span>
          </div>
          <div class="stat">
            <span class="stat-val"><%=watchlistCount%></span>
            <span class="stat-label">Watchlist</span>
          </div>
          <div class="stat">
            <span class="stat-val"><%=totalHours%> hrs</span>
            <span class="stat-label">Time Watched</span>
          </div>
        </div>
        <% if (user.favoriteGenres && user.favoriteGenres.length > 0) { %>
          <div class="profile-favorites" style="margin-top:16px; text-align:center;">
            <strong>Favorite Genres:</strong> <%= user.favoriteGenres.join(', ') %>
          </div>
        <% } else { %>
          <div class="profile-favorites" style="margin-top:16px; text-align:center; color:#888;">
            No favorite genres selected yet.
          </div>
        <% } %>
        <div class="profile-actions">
          <a href="/profile/edit" class="btn btn-secondary">Edit Profile</a>
          <a href="/profile/logout" class="btn btn-danger">Logout</a>
        </div>

        
      </div>
    </div>
  </body>
</html>
