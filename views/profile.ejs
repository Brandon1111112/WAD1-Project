<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile – IAMdb</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('partials/navbar') %>
    <div class="page-container-sm">
      <div class="profile-header">
        <h1 class="page-title">My Profile</h1>
        <p class="page-subtitle">Manage your account and preferences</p>
      </div>

      <div class="profile-card-enhanced">
        <div class="profile-cover"></div>
        <div class="profile-content">
          <img src="/img/default-profile.jpg" class="profile-img-large" alt="Profile" />
          <div class="profile-info">
            <h2 class="profile-name"><%= user.name %></h2>
            <p class="profile-email"><%= user.email %></p>
          </div>

          <div class="profile-stats-grid">
            <div class="stat-card">
              <div class="stat-number"><%=watchedCount%></div>
              <div class="stat-label">Movies Watched</div>
            </div>
            <div class="stat-card">
              <div class="stat-number"><%=reviewCount%></div>
              <div class="stat-label">Reviews Written</div>
            </div>
            <div class="stat-card">
              <div class="stat-number"><%=watchlistCount%></div>
              <div class="stat-label">In Watchlist</div>
            </div>
            <div class="stat-card">
              <div class="stat-number"><%=totalHours%></div>
              <div class="stat-label">Hours Watched</div>
            </div>
          </div>

          <% if (user.favoriteGenres && user.favoriteGenres.length > 0) { %>
            <div class="profile-section">
              <h3 class="profile-section-title">Favorite Genres</h3>
              <div class="genre-badges">
                <% user.favoriteGenres.forEach(genre => { %>
                  <span class="genre-badge-item"><%= genre %></span>
                <% }); %>
              </div>
            </div>
          <% } else { %>
            <div class="profile-section">
              <p class="profile-empty">No favorite genres selected yet. <a href="/profile/edit">Add some →</a></p>
            </div>
          <% } %>

          <div class="profile-actions-bottom" style="display:flex; gap:10px; width:100%; align-items:center;">
            <a href="/profile/edit" class="btn btn-secondary btn-lg" style="flex:1; min-width:120px; text-align:center;">✎ Edit Profile</a>
            <a href="/profile/delete" class="btn btn-danger btn-lg" style="flex:1.5; min-width:180px; text-align:center;">🗑️ Delete Account</a>
            <a href="/profile/logout" class="btn btn-danger btn-lg" style="flex:1; min-width:120px; text-align:center;">Logout</a>
          </div>
      </div>
    </div>
  </body>
</html>
