<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Delete Reply – IAMdb</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="page-container-xs" style="padding-top:48px;">
    <% if (result) { %>
      <div class="confirm-card">
        <div class="confirm-title">Delete Reply</div>
        <p style="font-size:13px;color:var(--text-2);margin:10px 0 4px;">The following reply will be permanently removed:</p>
        <div class="nb-card" style="text-align:left;margin:14px 0;">
          <div class="nb-message"><%= result.reply %></div>
        </div>
        <div class="confirm-warning">This action is permanent and cannot be undone.</div>
        <% if (msg) { %><div class="alert alert-error" style="margin-top:10px;"><%= msg %></div><% } %>
        <form action="/noticeboard/<%= result._id %>/reply/delete" method="POST">
          <input type="hidden" name="replyID" value="<%= result._id %>">
          <input type="hidden" name="userID" value="<%= userID %>">
          <div class="confirm-actions">
            <a href="/noticeboard/<%= String(result.parentPostID) %>/replies" class="btn btn-ghost">Cancel</a>
            <button class="btn btn-danger" type="submit">Delete Reply</button>
          </div>
        </form>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>Reply not found.</p>
        <a href="/noticeboard" class="btn btn-ghost" style="margin-top:16px;display:inline-flex;">Back to Noticeboard</a>
      </div>
    <% } %>
  </div>
</body>
</html>
